# Maintainer: dankcuddlybear <dankcuddlybear@protonmail.com>
pkgname=vapour-os-bootscreen
pkgver=0.1
pkgrel=3
pkgdesc='Vapour OS Graphical boot screen. Uses HackBGRT (https://github.com/Metabolix/HackBGRT).'
arch=(x86_64)
url='https://github.com/dankcuddlybear/Vapour-OS'
install=vapour-os-bootscreen.install
depends=('plymouth-git')
source=('https://github.com/Metabolix/HackBGRT/releases/download/v1.5.1/HackBGRT-1.5.1.zip')
sha512sums=('d4a362058cac10e3fa31665ee72370e0f4854fea07d9386112f0525bf4643f9d14fae25adf824fe2ab3723be2dd574c67491cc38174a989fa233e0d75e24ca84')
package() {
	cd "$srcdir"
	cd ../
	filesdir="$(pwd)/files"
	cp -r "$filesdir/usr" "$pkgdir"
	mkdir -p "$pkgdir/boot/EFI/HackBGRT" "$pkgdir/opt/vapour-os/kparams.d"
	mv "$srcdir/HackBGRT-1.5.1/bootx64.efi" "$pkgdir/boot/EFI/HackBGRT/bootx64.efi"
}
