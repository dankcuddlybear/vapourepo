pkgname=vapour-os
pkgver=0.1
pkgrel=7
pkgdesc='Vapour OS core system'
arch=(x86_64)
url='https://github.com/dankcuddlybear/Vapour-OS'
install=vapour-os.install
depends=(
	# Minimal bootable system
	'base' 'efibootmgr' 'linux-zen' 'linux-firmware' 'sudo'
	# Compilers/makedepends
	'autoconf' 'automake' 'bison' 'fakeroot' 'gcc' 'git' 'linux-zen-headers' 'make' 'patch' 'pkgconf' 'which' 'yay'
	# Power saving, hardware protection, safety features
	'hdparm'
	# Performance enhancements
	'ananicy-cpp' 'ananicy-rules-git' 'irqbalance' 'realtime-privileges' 'rtirq'
	# Filesystems
	'dosfstools' 'mtools' 'ntfs-3g'
	# Archives
	'p7zip' 'unrar'
	# Networking
	'networkmanager' 'nss-mdns'
	# Utilities
	'man-db' 'man-pages'
	# Terminal font for HiDPI/LoDPI support
	'terminus-font'
)
optdepends=('amd-ucode: AMD microcode'
	'intel-ucode: Intel microcode'
	'vapour-os-amdgpu: AMD GPU drivers'
	'vapour-os-bootscreen: Graphical boot screen'
	'vapour-os-gaming: Windows/Linux gaming libraries and software'
	'vapour-os-gnome: GNOME X11/Wayland shell and utilities'
	'vapour-os-gui: X11 GUI with Pipewire sound server'
	'vapour-os-i915: Intel GPU drivers'
	'vapour-os-i915-gen3-6: Intel GPU drivers (gen 3-6)'
	'vapour-os-kde: KDE X11 desktop and utilities'
	'vapour-os-multimedia: Audio/video codecs and disc support'
	'vapour-os-portable: For portable devices like laptops or handheld PCs'
	'vapour-os-printing: CUPS printing and printer drivers'
	'vapour-os-xfce: XFCE X11 desktop and utilities'
)
source=('vapour-os-files.tar.gz')
sha512sums=('628793037ebbbf8718133949834a623f89bf397bddf438c7877d4fd8857b2d2a50e1f69cddcc6d57475460135e5f03e31dc845a24ded2ee23e55de6e0c14c7ea')
package() {
	mv $srcdir/etc $pkgdir
	mv $srcdir/opt $pkgdir
	mv $srcdir/usr $pkgdir
}