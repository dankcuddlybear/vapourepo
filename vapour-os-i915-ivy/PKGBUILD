# Maintainer: dankcuddlybear <dankcuddlybear@protonmail.com>
pkgname=vapour-os-i915-ivy
pkgver=1.1.2
pkgrel=1
pkgdesc='Vapour OS Intel GPU drivers for OpenGL, Vulkan and hardware video acceleration. For gen 3 (Ivy Bridge) up to gen 6 (Skylake/Kabylake). WARNING: Some module options taint the kernel.'
arch=(x86_64)
url='https://github.com/dankcuddlybear/Vapour-OS'
depends=('lib32-libva-intel-driver'
    'lib32-mesa'
    'lib32-vulkan-intel'
    'libva-intel-driver'
    'vapour-os-gui'
    'vulkan-intel'
    'xf86-video-intel'
)
provides=('vapour-os-gpudriver')
conflicts=('vapour-os-i915')
package() {
	cd "$srcdir"
	cd ../
	filesdir="$(pwd)/files"
	cp -r "$filesdir/opt" "$pkgdir"
	cp -r "$filesdir/usr" "$pkgdir"
}
