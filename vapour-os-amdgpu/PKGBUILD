pkgname=vapour-os-amdgpu
pkgver=1.1.1
pkgrel=1
pkgdesc='Vapour OS AMD GPU multilib drivers for OpenGL, Vulkan, OpenCL and hardware video acceleration.'
arch=(x86_64)
url='https://github.com/dankcuddlybear/Vapour-OS'
backup=(etc/X11/xorg.conf.d/20-amdgpu.conf)
depends=('lib32-libva-mesa-driver'
    'lib32-mesa'
    'lib32-mesa-vdpau'
    'lib32-opencl-mesa'
    'lib32-vulkan-radeon'
    'libva-mesa-driver'
    'mesa-vdpau'
    'vapour-os-gui'
    'vulkan-radeon'
    'xf86-video-amdgpu'
)
provides=('vapour-os-gpudriver')
package() {
	cd "$srcdir"
	cd ../
	filesdir="$(pwd)/files"
	cp -r "$filesdir/etc" "$pkgdir"
}