#!/bin/sh
[ $(whoami) != "root" ] && echo "[ERROR] You must run this script with root priviliges." && exit 1
SCRIPT_DIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
KEYMAP=$1
[ -z $KEYMAP ] && echo "[ERROR] No keymap specified - will default to US." && exit 1

mkdir -P /etc/X11/xorg.conf.d
localectl set-keymap $KEYMAP
XKEYMAP=$(localectl | grep -sm 1 "X11 Layout" | cut -c19-30)
$SCRIPT_DIR/setvar set /etc/vconsole.conf KEYMAP $KEYMAP

# Create X11 keyboard config
echo "# This file was generated by Vapour OS. Any changes to this file will be lost after the next keymap configuration." > /etc/X11/xorg.conf.d/00-keyboard.conf
echo "Section \"InputClass\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
echo "    Identifier \"system-keyboard\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
echo "    MatchIsKeyboard \"on\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
echo "    Option \"XkbLayout\" \"$XKEYMAP\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
echo "EndSection" >> /etc/X11/xorg.conf.d/00-keyboard.conf
