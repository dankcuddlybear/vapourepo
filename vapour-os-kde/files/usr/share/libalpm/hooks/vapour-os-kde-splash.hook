[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Target = breeze

[Action]
Description = Replace Plasma's default splash screen
When = PostTransaction
Exec = sh -c 'rm -rf /usr/share/plasma/look-and-feel/org.kde.breeze.desktop/contents/splash; cp -r /opt/vapour-os/vapour-os-kde/splash /usr/share/plasma/look-and-feel/org.kde.breeze.desktop/contents'
