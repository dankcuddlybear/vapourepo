#!/bin/bash
exit 1
# Vapour OS config tool (CLI). Configure various critical system settings.
# This script will run once after installing Vapour OS.
# If you didn't use the live USB installer, your system will work but some settings will be unset. You will need to run voscfg again.
[ $(whoami) != "root" ] && echo "[ERROR] You must run this script with root priviliges." && exit 1
[ -f /mnt/options.conf ] && . /mnt/options.conf
[ -f /etc/vapour-os/display.conf ] && . /etc/vapour-os/display.conf
[ -f /etc/vconsole.conf ] && . /etc/vconsole.conf
unset ANSWER CFG_PARTIAL CFG_LOCALE CFG_TIMEZONE CFG_KEYMAP CFG_XKEYMAP CFG_SCALE CFG_NETWORK CFG_FSTAB CFG_BOOTLOADER CFG_INITRAMFS GRAPHICAL UPDATE_CONSOLE UPDATE_DISPLAY UPDATE_XKEYMAP XERROR
INTERACTIVE=1

PrintHelp() {
echo "Usage: $0 [OPTIONS]"
echo "    -h  Show this info"
echo "    -a  Auto-configure missing options (no user input)"
echo "    -l  Set system language and locale"
echo "    -t  Set system time zone"
echo "    -k  Set console keyboard layout"
echo "    -x  Set X11 keyboard layout. Warning: xkeymaps are named differently from console keymaps"
echo "    -s  Set X11 display scaling and console font size"
echo "    -n  Configure hostname and other network settings"
echo "    -b  Edit kernel parameters and update bootloader entries with package provided parameters"
echo "    -i  Update initramfs with package provided changes"
}

while getopts ":haltkxsnbi" option; do
	case $option in
		h)
			PrintHelp
			exit;;
		a)
			INTERACTIVE=0;;
		l)
			CFG_LOCALE=1
			CFG_PARTIAL=1;;
		t)
			CFG_TIMEZONE=1
			CFG_PARTIAL=1;;
		k)
			CFG_KEYMAP=1
			CFG_PARTIAL=1;;
		x)
			CFG_XKEYMAP=1
			CFG_PARTIAL=1;;
		s)
			CFG_SCALE=1
			CFG_PARTIAL=1;;
		n)
			CFG_NETWORK=1
			CFG_PARTIAL=1;;
		b)
			CFG_BOOTLOADER=1
			CFG_PARTIAL=1;;
		i)
			CFG_INITRAMFS=1
			CFG_PARTIAL=1;;
		\?)
			echo "[ERROR] Invalid option"
			PrintHelp
			exit 1;;
	esac
done
[ $INTERACTIVE == 1 ] && echo "Interactive mode" || echo "Auto-configuration mode"

NetConfig() {
	echo $HOSTNAME > /etc/hostname
	echo "127.0.0.1 localhost" > /etc/hosts
	echo "::1 localhost" >> /etc/hosts
	echo "127.0.1.1 $HOSTNAME" >> /etc/hosts
}

SetLocale() {
	echo "$1.UTF-8 UTF-8" > /etc/locale.gen
	echo "en_US.UTF-8 UTF-8" >> /etc/locale.gen
	echo "" >> /etc/locale.gen
	locale-gen
	echo "LANG=$1.UTF-8" > /etc/locale.conf
	echo "LC_ALL=$1.UTF-8" >> /etc/locale.conf
	echo "LC_CTYPE=$1.UTF-8" >> /etc/locale.conf
	echo "LC_NUMERIC=$1.UTF-8" >> /etc/locale.conf
	echo "LC_TIME=$1.UTF-8" >> /etc/locale.conf
	echo "LC_COLLATE=$1.UTF-8" >> /etc/locale.conf
	echo "LC_MONETARY=$1.UTF-8" >> /etc/locale.conf
	echo "LC_MESSAGES=$1.UTF-8" >> /etc/locale.conf
	echo "LC_PAPER=$1.UTF-8" >> /etc/locale.conf
	echo "LC_NAME=$1.UTF-8" >> /etc/locale.conf
	echo "LC_ADDRESS=$1.UTF-8" >> /etc/locale.conf
	echo "LC_TELEPHONE=$1.UTF-8" >> /etc/locale.conf
	echo "LC_MEASUREMENT=$1.UTF-8" >> /etc/locale.conf
	echo "LC_IDENTIFICATION=$1.UTF-8" >> /etc/locale.conf
	echo "" >> /etc/locale.conf
}

SetConsole() {
	echo "# This file was automatically generated by voscfg. Any changes to this file may be lost next time voscfg is run." > /etc/vconsole.conf
	echo "KEYMAP=$KEYMAP" >> /etc/vconsole.conf
	echo "FONT=$CONSOLEFONT" >> /etc/vconsole.conf
}

SetXKeymap() {
	echo "# This file was automatically generated by voscfg. Any changes to this file may be lost next time voscfg is run." > /etc/X11/xorg.conf.d/00-keyboard.conf
	echo "Section \"InputClass\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
	echo "    Identifier \"system-keyboard\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
	echo "    MatchIsKeyboard \"on\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
	echo "    Option \"XkbLayout\" \"gb\"" >> /etc/X11/xorg.conf.d/00-keyboard.conf
	echo "EndSection" >> /etc/X11/xorg.conf.d/00-keyboard.conf
}

SetDisplay() {
	echo "DISPLAY_WIDTH=$DISPLAY_WIDTH" > /etc/vapour-os/display.conf
	echo "DISPLAY_HEIGHT=$DISPLAY_HEIGHT" >> /etc/vapour-os/display.conf
	echo "DISPLAY_XRES=$DISPLAY_XRES" >> /etc/vapour-os/display.conf
	echo "DISPLAY_YRES=$DISPLAY_YRES" >> /etc/vapour-os/display.conf
	echo "DISPLAY_NAME=\"$DISPLAY_NAME\"" >> /etc/vapour-os/display.conf
	# Calculate display scale
	DISPLAY_XSCALE=$(awk "BEGIN {print $DISPLAY_XRES/$DISPLAY_WIDTH/0.04}")
	DISPLAY_XSCALE=${DISPLAY_XSCALE%.*}
	DISPLAY_YSCALE=$(awk "BEGIN {print $DISPLAY_YRES/$DISPLAY_HEIGHT/0.04}")
	DISPLAY_YSCALE=${DISPLAY_YSCALE%.*}
	((DISPLAY_XSCALE > DISPLAY_YSCALE)) && DISPLAY_SCALE=$DISPLAY_XSCALE || DISPLAY_SCALE=$DISPLAY_YSCALE
	# Calculate font size
	if (($DISPLAY_SCALE < 81)); then CONSOLEFONT="ter-112n"
	elif (($DISPLAY_SCALE < 94)); then CONSOLEFONT="ter-114b"
	elif (($DISPLAY_SCALE < 106)); then CONSOLEFONT="ter-116b"
	elif (($DISPLAY_SCALE < 119)); then CONSOLEFONT="ter-118b"
	elif (($DISPLAY_SCALE < 131)); then CONSOLEFONT="ter-120b"
	elif (($DISPLAY_SCALE < 144)); then CONSOLEFONT="ter-122b"
	elif (($DISPLAY_SCALE < 162)); then CONSOLEFONT="ter-124b"
	elif (($DISPLAY_SCALE < 188)); then CONSOLEFONT="ter-128b"
	elif (($DISPLAY_SCALE > 188)); then CONSOLEFONT="ter-132b"; fi
	# Configure X11
	if [ -f /usr/bin/X ]; then
		# Calculate X cursor size
		if (($DISPLAY_SCALE < 117)); then XCURSOR_SIZE=24
		elif (($DISPLAY_SCALE < 159)); then XCURSOR_SIZE=32
		elif (($DISPLAY_SCALE < 234)); then XCURSOR_SIZE=48
		elif (($DISPLAY_SCALE < 334)); then XCURSOR_SIZE=64
		elif (($DISPLAY_SCALE > 334)); then XCURSOR_SIZE=96; fi
		# Set monitor size
		echo "# This file was automatically generated by voscfg. Any changes to this file may be lost next time voscfg is run." > /etc/X11/xorg.conf.d/90-monitor.conf
		echo "Section \"Monitor\"" >> /etc/X11/xorg.conf.d/90-monitor.conf
		echo "    Identifier \"$DISPLAY_NAME\"" >> /etc/X11/xorg.conf.d/90-monitor.conf
		echo "    DisplaySize $DISPLAY_WIDTH $DISPLAY_HEIGHT" >> /etc/X11/xorg.conf.d/90-monitor.conf
		echo "    Option \"UseEdidDpi\" \"false\"" >> /etc/X11/xorg.conf.d/90-monitor.conf
		echo "EndSection" >> /etc/X11/xorg.conf.d/90-monitor.conf
	fi
}

# Language and locale
if [ $INTERACTIVE == 0 ]; then
	if [ ! -f /etc/locale.conf ]; then
		if [ -z $LOCALE ]; then echo "[WARNING] Locale not set. Please run /opt/vapour-os/vosconfig"
		else echo "Setting locale to $LOCALE"; SetLocale $LOCALE; fi
	else echo "Locale already set to $LOCALE"; fi
else
	if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_LOCALE ]; then
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter locale keymap (or type l to list locales) (currently set: $LOCALE - type without the \".UTF-8\" at the end): " ANSWER
			if [ $ANSWER == "l" ] || [ $ANSWER == "L" ]; then
				ls -d /usr/share/locale/*/ | sed 's/\/usr\/share\/locale\///g' | sed 's/\///g' | less -X
			else
				if [ -d /usr/share/locale/$ANSWER ]; then SetLocale $ANSWER; CONTINUE=1
				else echo "Invalid locale!"; fi
			fi
		done
	fi
fi

# Timezone
if [ $INTERACTIVE == 0 ]; then
	if [ ! -f /etc/localtime ]; then
		if [ -z $TIMEZONE ]; then echo "[WARNING] Time zone not set. Please run /opt/vapour-os/vosconfig"
		else echo "Setting timezone to $TIMEZONE"; ln -sf /usr/share/zoneinfo/$TIMEZONE /etc/localtime; fi
	else echo "Timezone already set to $TIMEZONE"; fi
else
	if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_TIMEZONE ]; then
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter your timezone (or type l to list timezones) (currently set: $TIMEZONE): " ANSWER
			if [ $ANSWER == "l" ] || [ $ANSWER == "L" ]; then timedatectl list-timezones
			else
				if [ -f /usr/share/zoneinfo/$ANSWER ]; then
					ln -sf /usr/share/zoneinfo/$ANSWER /etc/localtime
					CONTINUE=1
				else
					echo "[ERROR] Invalid timezone"
				fi
			fi
		done
	fi
fi

# Console keymap
if [ $INTERACTIVE == 0 ]; then
	if [ ! -f /etc/vconsole.conf ]; then
		if [ -z $KEYMAP ]; then echo "[WARNING] Console keymap not set - will default to \"us\" (United States). Please run /opt/vapour-os/vosconfig"
		else echo "Setting console keymap to $KEYMAP"; UPDATE_CONSOLE=1; fi
	else echo "Console keymap already set to $KEYMAP"; fi
else
	if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_KEYMAP ]; then
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter console keymap (or type l to list keymaps) (currently set: $KEYMAP): " ANSWER
			if [ $ANSWER == "l" ] || [ $ANSWER == "L" ]; then localectl list-keymaps
			else localectl set-keymap $ANSWER && KEYMAP="$ANSWER" && UPDATE_CONSOLE=1 && CONTINUE=1; fi
		done
	fi
fi

# X11 keymap
if [ -f /usr/bin/X ]; then
	if [ $INTERACTIVE == 0 ]; then
		if [ ! -f /etc/X11/xorg.conf.d/00-keyboard.conf ]; then
			if [ -z XKEYMAP ]; then echo "[WARNING] X11 keymap not set - will default to \"us\" (United States). Please run /opt/vapour-os/vosconfig"
			else echo "Setting X keymap to $XKEYMAP"; UPDATE_XKEYMAP=1; fi
		else echo "X keymap already set to $XKEYMAP"; fi
	else
		if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_XKEYMAP ]; then
			CONTINUE=0; while [ $CONTINUE == 0 ]; do
				read -p "Enter X11 keymap (or type l to list keymaps) (currently set: $XKEYMAP): " ANSWER
				if [ $ANSWER == "l" ] || [ $ANSWER == "L" ]; then localectl list-x11-keymap-layouts
				else localectl set-x11-keymap $ANSWER && XKEYMAP="$ANSWER" && UPDATE_XKEYMAP=1 && CONTINUE=1; fi
			done
		fi
	fi
else
	echo "X11 not installed, skipping X keymap config..."
fi

# Network
if [ $INTERACTIVE == 0 ]; then
	if [ ! -f /etc/hostname ] || [ ! -f /etc/hosts ]; then
		if [ -z $HOSTNAME ]; then echo "[WARNING] Hostname/hosts not set. Please run /opt/vapour-os/vosconfig"
		else echo "Setting hostname to $HOSTNAME"; NetConfig; fi
	else echo "Hostname already set to $HOSTNAME"; fi
else
	if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_NETWORK ]; then
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter hostname for this machine (currently set: $HOSTNAME): " ANSWER
			if [ -z $ANSWER ]; then echo "[ERROR] This cannot be blank!"
			else HOSTNAME=$ANSWER; NetConfig; CONTINUE=1; fi
		done
	fi
fi

# Display
if [ $INTERACTIVE == 0 ]; then
	if [ ! -f /etc/X11/xorg.conf.d/90-monitor.conf ] || [ ! -f /etc/vconsole.conf ]; then
		if [ -z $DISPLAY_XRES ] || [ -z $DISPLAY_YRES ] || [ -z $DISPLAY_WIDTH ] || [ -z $DISPLAY_HEIGHT ]; then
			echo "[WARNING] Display parameters not set in /etc/vapour-os/device.conf - will default to 96DPI. If you wish to change this run /opt/vapour-os/vosconfig"
		else
			echo "Setting display properties for $DISPLAY_NAME: $DISPLAY_XRES x $DISPLAY_YRES pixels, $DISPLAY_WIDTH x $DISPLAY_HEIGHT millimetres"
			UPDATE_CONSOLE=1
		fi
	else
		echo "Display $DISPLAY_NAME already set to $DISPLAY_XRES x $DISPLAY_YRES pixels, $DISPLAY_WIDTH x $DISPLAY_HEIGHT millimetres"
	fi
else
	if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_SCALE ]; then
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter display width in millimetres (currently set: $DISPLAY_WIDTH): " ANSWER
			if (($ANSWER > 0)); then DISPLAY_WIDTH=$ANSWER; CONTINUE=1
			else echo "[ERROR] Must be a positive, non-zero integer"; fi
		done
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter display height in millimetres (currently set: $DISPLAY_HEIGHT): " ANSWER
			if (($ANSWER > 0)); then DISPLAY_HEIGHT=$ANSWER; CONTINUE=1
			else echo "[ERROR] Must be a positive, non-zero integer"; fi
		done
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter display width in pixels (currently set: $DISPLAY_XRES): " ANSWER
			if (($ANSWER > 0)); then DISPLAY_XRES=$ANSWER; CONTINUE=1
			else echo "[ERROR] Must be a positive, non-zero integer"; fi
		done
		CONTINUE=0; while [ $CONTINUE == 0 ]; do
			read -p "Enter display height in pixels (currently set: $DISPLAY_YRES): " ANSWER
			if (($ANSWER > 0)); then DISPLAY_YRES=$ANSWER; CONTINUE=1
			else echo "[ERROR] Must be a positive, non-zero integer"; fi
		done
		if [ -f /usr/bin/X ]; then
			xrandr &> /dev/null && DISPLAY_NAME=$(xrandr | grep -sm 1 "connected primary" | cut -d ' ' -f 1) || XERROR=1
			if [ $XERROR == 1 ]; then
				echo "X not running - unable to detect primary monitor. Please enter name of primary monitor (this can be found by running xrandr in an X session). Make sure this is correct or X will fail to start."
				CONTINUE=0; while [ $CONTINUE == 0 ]; do
					read -p "Primary monitor name (currently set: $DISPLAY_NAME): " ANSWER
					if [ -z $ANSWER ]; then echo "[ERROR] This cannot be blank!"
					else DISPLAY_NAME="$ANSWER"; CONTINUE=1; fi
				done
			fi
		fi
		UPDATE_CONSOLE=1
	fi
fi

[ ! -z $UPDATE_CONSOLE ] && SetDisplay && SetConsole
[ ! -z $UPDATE_XKEYMAP ] && SetXKeymap

# Bootloader
echo "Auto-configuring bootloader..."
if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_BOOTLOADER ]; then
	. /opt/vapour-os/partinfo # Find UUID of root partition
	unset KPARAMS
	unset KPARAMS_GRAPHICAL
	# Read additional kernel parameters in /opt/vapour-os/kparams.d
	KPARAMS=$(cat /opt/vapour-os/kparams.d/main)
	[ -f /opt/vapour-os/kparams.d/graphical ] && KPARAMS_GRAPHICAL=$(cat /opt/vapour-os/kparams.d/graphical)
	mkdir -p /boot/loader/entries
	# Configure bootloader
	echo "default arch.conf" > /boot/loader/loader.conf
	echo "timeout 2" >> /boot/loader/loader.conf
	echo "console-mode keep" >> /boot/loader/loader.conf
	echo "editor no" >> /boot/loader/loader.conf
	echo "auto-firmware no" >> /boot/loader/loader.conf
	echo "random-seed-mode always" >> /boot/loader/loader.conf
	# Create default bootloader entry
	echo "title Arch Linux" > /boot/loader/entries/arch.conf
	echo "linux /vmlinuz-linux-zen" >> /boot/loader/entries/arch.conf
	[ -f /boot/amd-ucode.img ] && echo "initrd /amd-ucode.img" >> /boot/loader/entries/arch.conf
	[ -f /boot/intel-ucode.img ] && echo "initrd /intel-ucode.img" >> /boot/loader/entries/arch.conf
	echo "initrd /initramfs-linux-zen.img" >> /boot/loader/entries/arch.conf
	echo "options $KPARAMS $KPARAMS_GRAPHICAL root=UUID=$ROOT_UUID" >> /boot/loader/entries/arch.conf
	# Create bootloader entry (fallback initramfs)
	echo "title Arch Linux (fallback initramfs)" > /boot/loader/entries/arch-fallback.conf
	echo "linux /vmlinuz-linux-zen" >> /boot/loader/entries/arch-fallback.conf
	[ -f /boot/amd-ucode.img ] && echo "initrd /amd-ucode.img" >> /boot/loader/entries/arch-fallback.conf
	[ -f /boot/intel-ucode.img ] && echo "initrd /intel-ucode.img" >> /boot/loader/entries/arch-fallback.conf
	echo "initrd /initramfs-linux-zen-fallback.img" >> /boot/loader/entries/arch-fallback.conf
	echo "options $KPARAMS root=UUID=$ROOT_UUID" >> /boot/loader/entries/arch-fallback.conf
fi

# Initramfs
echo "Auto-configuring initramfs..."
if [ -z $CFG_PARTIAL ] || [ ! -z $CFG_INITRAMFS ]; then
	[ -f /usr/bin/plymouth ] && GRAPHICAL=1
	echo "# This file was automatically generated by voscfg. Any changes to this file may be lost next time voscfg is run." > /etc/mkinitcpio.conf
	if [ -z $GRAPHICAL ]; then
		echo "MODULES=()" >> /etc/mkinitcpio.conf
	else
		[ $GPU0 == "intel" ] && echo "MODULES=(i915)" >> /etc/mkinitcpio.conf
		[ $GPU0 == "amd" ] && echo "MODULES=(amdgpu)" >> /etc/mkinitcpio.conf
		[ $GPU0 == "nvidia" ] && echo "MODULES=(nvidia)" >> /etc/mkinitcpio.conf
	fi
	echo "BINARIES=()" >> /etc/mkinitcpio.conf
	echo "FILES=()" >> /etc/mkinitcpio.conf
	if [ -z $GRAPHICAL ]; then
		echo "HOOKS=(autodetect base systemd sd-vconsole modconf block filesystems keyboard fsck)" >> /etc/mkinitcpio.conf
	else
		echo "HOOKS=(autodetect base systemd sd-vconsole modconf sd-plymouth block filesystems keyboard fsck)" >> /etc/mkinitcpio.conf
	fi
	echo "COMPRESSION=\"zstd\"" >> /etc/mkinitcpio.conf
	rm /boot/initramfs-*.img
	mkinitcpio -P
fi