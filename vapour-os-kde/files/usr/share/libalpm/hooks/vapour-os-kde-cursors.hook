[Trigger]
Type = Package
Operation = Install
Operation = Upgrade
Target = breeze

[Action]
Description = Replace Plasma's ugly default cursors
When = PostTransaction
Exec = sh -c 'rm -rf /usr/share/icons/breeze_cursors/cursors; cp -r /opt/vapour-os/vapour-os-kde/cursors /usr/share/icons/breeze_cursors'
