# This file is part of Vapour OS. Do not edit this file - any changes
# will be lost after the next update.
# Instead, put one or more custom xprofiles in /etc/xprofile.d

# Load scripts from /etc/xprofile.d
if test -d /etc/xprofile.d/; then
	for xprofile in /etc/xprofile.d/*.sh; do
		test -r "$xprofile" && . "x$profile"
	done
	unset xprofile
fi

# Set DPI
xrandr --dpi $QT_FONT_DPI
