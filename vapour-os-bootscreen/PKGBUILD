pkgname=vapour-os-bootscreen
pkgver=0.1
pkgrel=1
pkgdesc='Vapour OS Graphical boot screen. Uses HackBGRT which is NOT developed by me (https://github.com/Metabolix/HackBGRT).'
arch=(x86_64)
license=('MIT')
url='https://github.com/dankcuddlybear/Vapour-OS'
install=vapour-os-bootscreen.install
depends=('plymouth-git')
source=('kparams' 'https://github.com/Metabolix/HackBGRT/releases/download/v1.5.1/HackBGRT-1.5.1.zip')
sha512sums=('30d67aaa0e76972e9db9ce9d18c1ca5fab174f24cc40a5b444eb5eac42eb56058d848420374782c2be1507892ff8538b1a4f4bfd53ad0e430d0e51039ac3d05c' 'd4a362058cac10e3fa31665ee72370e0f4854fea07d9386112f0525bf4643f9d14fae25adf824fe2ab3723be2dd574c67491cc38174a989fa233e0d75e24ca84')
package() {
	mkdir -p $pkgdir/boot/EFI/HackBGRT $pkgdir/opt/vapour-os/kparams.d
	mv $srcdir/HackBGRT-1.5.1/bootx64.efi $pkgdir/boot/EFI/HackBGRT/bootx64.efi
	mv $srcdir/kparams $pkgdir/opt/vapour-os/kparams.d/silent
}