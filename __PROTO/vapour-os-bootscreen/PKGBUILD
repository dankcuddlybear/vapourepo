pkgname=vapour-os-bootscreen
pkgver=0.1
pkgrel=1
pkgdesc='Vapour OS Graphical boot screen'
arch=(any)
url='https://github.com/dankcuddlybear/Vapour-OS'
install=vapour-os-bootscreen.install
depends=('plymouth-git')
source=('vapour-os-bootscreen-files.tar.gz')
sha512sums=('1dbd179504f41a892f872d8a2312d100655bd2cca4f5bb32ade01584807f6505713137fab991eb15fe9bcddf31d159db4ab4e953b41a9dab8433d029f97e0932')
package() {
	mkdir -p $pkgdir/boot/vapour-os/kparams.d
	mv $srcdir/kparams $pkgdir/boot/vapour-os/kparams.d/silent
}