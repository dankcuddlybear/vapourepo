[Trigger]
Operation = Install
Operation = Upgrade
Type = Package
Target = pacman-mirrorlist

[Action]
Description = Upgrade Pacman mirrorlist
Depends = sed
When = PostTransaction
Exec = sh -c 'mv /etc/pacman.d/mirrorlist.pacnew /etc/pacman.d/mirrorlist &> /dev/null && sed "/Server = /s/^#//g" -i /etc/pacman.d/mirrorlist'
