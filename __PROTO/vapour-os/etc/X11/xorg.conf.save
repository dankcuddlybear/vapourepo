Section "InputClass"
    Identifier "system-keyboard"
    MatchIsKeyboard "on"
    Option "XkbLayout" "gb"
EndSection

Section "Device"
    Identifier "Intel Graphics"
    Driver "intel"
    Option "VideoRam" "262144"
    Option "TearFree" "false"
    Option "TripleBuffer" "true"
EndSection

Section "Device"
    Identifier "Nvidia Card"
    Driver "nvidia"
    VendorName "NVIDIA Corporation"
    BoardName "GeForce GTX 1660 Ti Mobile"
    Option "RegistryDwords" "PowerMizerLevel=0x2; PowerMizerDefaultAC=0x2"
    Option "NoLogo" "true"
    Option "ConnectToAcpid" "false"
    Option "EnableACPIBrightnessHotkeys" "false"
    #Option "Coolbits" "24"
    Option "TripleBuffer" "false"
EndSection
