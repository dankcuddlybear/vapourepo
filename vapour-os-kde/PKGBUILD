package() {
	mkdir -p $pkgdir/etc/xdg/autostart $pkgdir/usr/share/plymouth/themes/breeze
	mv $srcdir/pipewire-fix-kde.desktop $pkgdir/etc/xdg/autostart/pipewire-fix-kde.desktop
	mv $srcdir/breeze.plymouth $pkgdir/usr/share/plymouth/themes/breeze/breeze.plymouth
	mv $srcdir/bullet.png $pkgdir/usr/share/plymouth/themes/breeze/bullet.png
	mv $srcdir/entry.png $pkgdir/usr/share/plymouth/themes/breeze/entry.png
	mv $srcdir/script $pkgdir/usr/share/plymouth/themes/breeze/script
	mv $srcdir/spinner.png $pkgdir/usr/share/plymouth/themes/breeze/spinner.png
}