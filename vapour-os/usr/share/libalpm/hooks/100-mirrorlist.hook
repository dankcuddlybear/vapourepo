[Trigger]
Operation = Upgrade
Type = Package
Target = pacman-mirrorlist

[Action]
Description = Upgrade Pacman mirrorlist
Depends = sed
When = PostTransaction
Exec = /usr/bin/sh -c 'mv /etc/pacman.d/mirrorlist.pacnew /etc/pacman.d/mirrorlist; sed "/Server = /s/^#//g" -i /etc/pacman.d/mirrorlist; echo "Replaced mirrorlist with mirrorlist.pacnew"'